@startuml
!include style.puml
skinparam ArrowFontStyle plain

box UI UI_COLOR_T1
participant ":MainWindow" as MainWindow UI_COLOR
end box

box Security SECURITY_COLOR_T1
participant ":SecurityManager" as SecurityManager SECURITY_COLOR
end box

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box

[-> MainWindow : fillInnerParts()
activate MainWindow

MainWindow -[UI_COLOR]> SecurityManager : isAuthenticated()
activate SecurityManager SECURITY_COLOR

SecurityManager -[SECURITY_COLOR]> LogicManager : getAddressBookPassword()
activate LogicManager LOGIC_COLOR

LogicManager -[LOGIC_COLOR]> Model : getAddressBookPassword()
activate Model MODEL_COLOR

Model --[MODEL_COLOR]> LogicManager : storedPassword
deactivate Model

LogicManager --[LOGIC_COLOR]> SecurityManager : storedPassword
deactivate LogicManager

SecurityManager --[SECURITY_COLOR]> MainWindow : isAuthenticated
deactivate SecurityManager

opt !isAuthenticated
    MainWindow -[UI_COLOR]> MainWindow : handleSetup()
    activate MainWindow UI_COLOR_T1

    MainWindow --[UI_COLOR]> MainWindow
    deactivate MainWindow
end

[<-- MainWindow
deactivate MainWindow
@enduml
